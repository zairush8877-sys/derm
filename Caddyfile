# Aura: реверс-прокси с автоматическим HTTPS (Let's Encrypt).
# Сертификат выпускается через DNS-проверку (API Timeweb): проверка «извне
# по HTTP» до российского сервера из-за границы не доходит (таймауты),
# поэтому используем ACME DNS-01 — без входящего трафика.
# Требуется TIMEWEB_TOKEN в .env (панель Timeweb → «API и Terraform»).
aura-wellness.ru {
	encode gzip
	reverse_proxy app:8000
	tls {
		dns timeweb {
			ApiURL {env.TIMEWEB_API_URL}
			ApiToken {env.TIMEWEB_TOKEN}
		}
	}
}

# www → без www (постоянный редирект)
www.aura-wellness.ru {
	redir https://aura-wellness.ru{uri} permanent
	tls {
		dns timeweb {
			ApiURL {env.TIMEWEB_API_URL}
			ApiToken {env.TIMEWEB_TOKEN}
		}
	}
}

# Запасной доступ по IP/туннелю на 80-м порту (работает и пока DNS расходится)
:80 {
	encode gzip
	reverse_proxy app:8000
}
