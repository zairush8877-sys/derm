# Aura: базовый конфиг Caddy — ТОЛЬКО HTTP (:80), без попыток выпуска
# сертификата. Выпуском занимается исключительно контейнер lego (DNS-01
# через API Timeweb с ожиданием публикации записи на NS). Когда файлы
# сертификата появляются, scripts/caddy-entrypoint.sh переключает Caddy
# на Caddyfile.files (полноценный HTTPS) через caddy reload.
#
# Почему так: NS Timeweb публикуют новые записи с задержкой в минуты,
# и попытки Caddy валидироваться сразу после создания записи вечно
# промахивались, замусоривая зону и сжигая лимиты Let's Encrypt.
:80 {
	encode gzip
	reverse_proxy app:8000
}
