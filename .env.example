# Ключ Anthropic для реального анализа кожи через Claude vision.
# Если не задан — платформа автоматически работает в демо-режиме (mock).
ANTHROPIC_API_KEY=

# Модель Claude для фото-анализа (vision, максимум качества).
DERM_MODEL=claude-opus-4-8
# Модель чат-ассистента (быстрая и дешёвая).
DERM_CHAT_MODEL=claude-haiku-4-5

# Секрет для подписи токенов авторизации. В проде ОБЯЗАТЕЛЬНО замените!
DERM_SECRET=dev-secret-change-me

# Принудительно включить демо-режим (1 = да). По умолчанию включается, если нет ключа.
DERM_MOCK_MODE=

# Путь к базе данных SQLite.
DERM_DB_PATH=derm.db

# Демо-ключ для B2B API (X-API-Key). В проде замените на свой.
DERM_DEMO_API_KEY=demo-key-derm-2026

# --- Биллинг (платный AI-скан по фото: кожа/еда) ---
# Цена одного скана в рублях.
DERM_SCAN_PRICE_RUB=199
# Сколько бесплатных пробных сканов даётся новому пользователю.
DERM_FREE_TRIAL_SCANS=3
# Провайдер оплаты: demo (по умолчанию) | yookassa
DERM_PAYMENT_PROVIDER=demo
# Ключи ЮKassa (нужны только при DERM_PAYMENT_PROVIDER=yookassa)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- SMS-провайдер для кодов входа (OTP) ---
# Если не задан — демо-режим: код показывается прямо в интерфейсе (бесплатно).
# Провайдер: smsru (по умолчанию) | smsc
SMS_PROVIDER=smsru
# SMS.ru: api_id из личного кабинета (sms.ru -> Настройки -> API)
SMS_API_KEY=
# SMSC.ru: логин и API-пароль (нужны только при SMS_PROVIDER=smsc)
SMS_LOGIN=
SMS_PASSWORD=
# Имя отправителя (после модерации у провайдера), например AURA. Можно оставить пустым.
SMS_SENDER=

# --- Доставка СДЭК (после договора с ИП/юрлицом) ---
# Account и Secure password из ЛК СДЭК (Интеграция → API). Пусто = фикс-тарифы.
CDEK_ACCOUNT=
CDEK_PASSWORD=
# Код города отправления по справочнику СДЭК (44 = Москва, 137 = Санкт-Петербург)
CDEK_FROM_CITY=44

# --- Telegram-уведомления владельцу о новых заказах ---
# 1) В Telegram найдите @BotFather -> /newbot -> получите токен
# 2) Напишите своему боту любое сообщение, затем узнайте свой chat_id
#    через @userinfobot. Пусто = уведомления выключены.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- HTTPS-сертификат домена (DNS-проверка через API Timeweb) ---
# Панель Timeweb → «API и Terraform» → Создать токен. Без токена сертификат
# не выпустится (HTTP-проверка из-за границы до RU-сервера не доходит).
TIMEWEB_TOKEN=
# База API Timeweb (менять не нужно)
TIMEWEB_API_URL=https://api.timeweb.cloud/api/v1
